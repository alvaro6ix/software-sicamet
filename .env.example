# SICAMET CRM — variables de entorno
# Copia este archivo a .env y rellena con valores reales.
# NUNCA commitees el archivo .env (está en .gitignore).

# ─── Base de datos MySQL ──────────────────────────────────────────────────────
# Usado por docker-compose para inicializar el contenedor MySQL y por el backend
# para conectarse. Cambia el valor en cada despliegue.
DB_PASSWORD=cambia_esto_por_un_password_largo_y_aleatorio

# ─── JWT (autenticación) ──────────────────────────────────────────────────────
# Genera uno nuevo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Si lo cambias, todas las sesiones activas se invalidan.
JWT_SECRET=cambia_esto_por_un_secret_largo_y_aleatorio

# ─── Google Gemini AI (Bot PRO) ───────────────────────────────────────────────
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# ─── Dominio público (para enlaces en mensajes del bot) ───────────────────────
APP_URL=http://localhost:5173

# ─── CORS — orígenes permitidos (Sprint 14-C) ─────────────────────────────────
# Lista separada por coma de los orígenes que pueden llamar al backend.
# En dev: localhost:5173 (Vite). En prod: añade tu dominio (https://crm.sicamet.mx).
# Cualquier otro origen recibirá 'CORS bloqueado'.
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
