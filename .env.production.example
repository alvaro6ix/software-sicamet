# SICAMET CRM — variables de entorno para PRODUCCIÓN
# Copia este archivo a .env (en el VPS) y rellena con valores REALES.
# NUNCA commitees el .env real.

# ─── Base de datos MySQL ──────────────────────────────────────────────────────
# Genera un password fuerte. NO uses el de dev.
#   openssl rand -base64 32
DB_PASSWORD=GENERA_UN_PASSWORD_FUERTE_NUEVO

# ─── JWT (autenticación) ──────────────────────────────────────────────────────
# Genera con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Si lo cambias, todas las sesiones activas se invalidan.
JWT_SECRET=GENERA_UN_SECRET_NUEVO_LARGO_BASE64URL

# ─── Google Gemini AI (Bot PRO) ───────────────────────────────────────────────
# Obtener en: https://aistudio.google.com/app/apikey
# Si lo dejas vacío, el bot funciona pero sin respuestas IA dinámicas.
GEMINI_API_KEY=

# ─── Dominio público ──────────────────────────────────────────────────────────
# El dominio donde se sirve el CRM. Caddy obtiene SSL Let's Encrypt automáticamente.
# Si aún no tienes dominio: deja DOMAIN=:80 (servirá por HTTP en el puerto 80
# del VPS, accesible vía http://IP_DEL_VPS) y AUTO_HTTPS=off.
DOMAIN=crm.sicamet.mx
APP_URL=https://crm.sicamet.mx
AUTO_HTTPS=on

# Email para notificaciones de Let's Encrypt (renovación próxima a vencer, etc.)
ADMIN_EMAIL=admin@sicamet.mx

# ─── CORS — orígenes permitidos ───────────────────────────────────────────────
# El dominio público debe estar aquí. Si tienes subdominios o staging, agrégalos
# separados por coma. Cualquier otro origen recibirá 'CORS bloqueado'.
CORS_ORIGINS=https://crm.sicamet.mx
